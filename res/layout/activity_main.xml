xml
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/purple_700"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Control Your Screen Time"
        android:textSize="16sp"
        android:textColor="@color/black"
        android:alpha="0.7"
        android:layout_marginBottom="40dp" />

    <!-- Permission Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Required Permissions"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvUsageAccessStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❌ Usage Access"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvOverlayStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❌ Draw Over Apps"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAccessibilityStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="❌ Accessibility Service"
                android:textSize="16sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnRequestPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enable_permissions"
        android:textSize="16sp"
        android:padding="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp" />

    <!-- Monitoring Status -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/service_status"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvMonitoringStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/monitoring_inactive"
        android:textSize="16sp"
        android:textColor="@color/block_bg"
        android:gravity="center"
        android:padding="16dp"
        android:background="@android:color/darker_gray"
        android:layout_marginBottom="24dp" />

    <!-- Info Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️ Monitored Apps"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Instagram\n• Time Limit: 10 minutes\n• Cooldown: 30 minutes"
        android:textSize="14sp"
        android:alpha="0.8"
        android:lineSpacingExtra="4dp" />

</LinearLayout>
